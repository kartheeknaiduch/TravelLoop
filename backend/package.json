{
  "name": "traveloop-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "db:push:force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "codegen": "orval --config ./orval.config.ts && pnpm run typecheck"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "dotenv": "^17.2.3",
    "express": "^5",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "orval": "^8.5.2",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  }
}
